{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test_output.schema.json",
  "title": "Skill Tester Output",
  "description": "Output format produced by skill-tester, consumed by evolution loop as input.",
  "type": "object",
  "required": ["skill_name", "overall_score", "module_scores", "test_timestamp"],
  "properties": {
    "skill_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "module_scores": {
      "type": "object",
      "required": ["tool_usage", "prompt_alignment", "output_schema", "error_handling", "self_description", "edge_case_coverage", "security_audit"],
      "properties": {
        "tool_usage": {"type": "number", "minimum": 0, "maximum": 100},
        "prompt_alignment": {"type": "number", "minimum": 0, "maximum": 100},
        "output_schema": {"type": "number", "minimum": 0, "maximum": 100},
        "error_handling": {"type": "number", "minimum": 0, "maximum": 100},
        "self_description": {"type": "number", "minimum": 0, "maximum": 100},
        "edge_case_coverage": {"type": "number", "minimum": 0, "maximum": 100},
        "security_audit": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "failing_modules": {
      "type": "array",
      "items": {"type": "string"}
    },
    "degraded_modules": {
      "type": "array",
      "items": {"type": "string"}
    },
    "execution_time_ms": {"type": "number", "minimum": 0},
    "schema_valid": {"type": "boolean"},
    "exit_code": {"type": "integer"},
    "test_timestamp": {"type": "string", "format": "date-time"},
    "previous_score": {"type": "number"},
    "model_id": {"type": "string"}
  }
}
